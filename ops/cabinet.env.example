# Copy this file to ops/cabinet.env and edit for the real cabinet.

# Hostname or IP address reachable from this development machine.
KARLO_CABINET_HOST=karlo-cabinet.local

# SSH user used for deployment. This user must be able to run sudo on the cabinet.
KARLO_CABINET_SSH_USER=ben

# Allow the SSH deploy user to run sudo without a password on the cabinet.
# Useful for a dedicated arcade machine and required for fully unattended deploys.
KARLO_PASSWORDLESS_SUDO=1

# Dedicated local account that owns the cabinet session.
KARLO_CABINET_USER=karlo

# GitHub repo and branch/ref used for artifact lookup.
KARLO_GITHUB_REPO=bentruyman/karlo
KARLO_GITHUB_REF=main

# Artifact produced by .github/workflows/linux-artifact.yml.
KARLO_ARTIFACT_NAME=karlo-linux-x64
KARLO_WORKFLOW=linux-artifact.yml

# Remote scratch directory for each deploy.
KARLO_REMOTE_TMP=/tmp/karlo-deploy

# Provision installs the kiosk service and cabinet runtime dependencies.
KARLO_PROVISION=1

# Boot tuning disables the normal display manager, sets multi-user target,
# quiets boot logs, and gives tty1 to Karlo.
KARLO_OPTIMIZE_BOOT=1

# Session backend for the cabinet service. x11 is the default because
# Tauri/WebKit is more reliable there on the tested Ubuntu cabinet image.
KARLO_SESSION_BACKEND=x11

# Leave WebKit compositing enabled for video playback. Set to 1 only if the
# cabinet shows a blank WebKit window with the normal compositor path.
KARLO_WEBKIT_DISABLE_COMPOSITING=0

# Weston shell used by the cabinet session. desktop is more compatible with
# Tauri/WebKit than kiosk on some Ubuntu releases. Only used with
# KARLO_SESSION_BACKEND=wayland.
KARLO_WESTON_SHELL=desktop

# Restart Karlo after installing the package.
KARLO_RESTART=1
