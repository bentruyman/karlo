{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Karlo",
  "version": "0.1.0",
  "identifier": "com.truyman.karlo",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Karlo",
        "width": 1280,
        "height": 960,
        "minWidth": 960,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "backgroundColor": "#05070b"
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src ipc: http://ipc.localhost http://127.0.0.1:*; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' asset: http://asset.localhost karlo-media: http://karlo-media.localhost; media-src 'self' asset: http://asset.localhost karlo-media: http://karlo-media.localhost http://127.0.0.1:*",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "/srv/karlo/library/**",
          "$DOWNLOAD/**",
          "$HOME/Development/src/github.com/bentruyman/karlo-library/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Entertainment",
    "shortDescription": "LCD-first MAME cabinet frontend",
    "icon": ["icons/icon.png", "icons/Icon@2x.png"]
  }
}
